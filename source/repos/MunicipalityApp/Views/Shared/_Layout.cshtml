@{
    Layout = null;
    var title = ViewData["Title"] ?? "Municipal Services";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@title</title>

    <!-- Tailwind CDN for quick prototyping -->
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-gradient-to-b from-white via-[#f8f6f1] to-white text-gray-800">
    <header class="bg-[linear-gradient(90deg,#6b4f3b, #3a8a4a)] text-white shadow-md">
        <div class="container mx-auto px-4 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3">
                <div class="bg-white text-[#3a8a4a] rounded-full p-2">🌿</div>
                <div>
                    <h1 class="text-lg font-semibold">CommunityCare</h1>
                    <div class="text-xs opacity-90">Report • Events • Status</div>
                </div>
            </a>
            <nav class="flex items-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="text-sm hover:underline">Home</a>
                <a asp-controller="Issues" asp-action="Report" class="bg-white text-[#6b4f3b] px-3 py-1 rounded-full text-sm shadow-sm hover:bg-[#f5efe6] transition">Report Issue</a>
                <a asp-controller="Events" asp-action="Index" class="text-sm hover:underline">Local Events</a>
                <a asp-controller="ServiceRequests" asp-action="Index" class="text-sm hover:underline">Service Status</a>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <footer class="bg-[#f5efe6] mt-12">
        <div class="container mx-auto px-4 py-6 text-center text-sm text-[#6b4f3b]">
            © CommunityCare — Demo (no DB) — Tailwind prototype
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>







