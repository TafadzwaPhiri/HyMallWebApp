@model MunicipalityApp.Models.Issue
@{
    ViewData["Title"] = "Issue Details";
}

<div class="max-w-4xl mx-auto p-6 bg-white rounded-2xl shadow">
    <h2 class="text-2xl font-semibold text-[#3E7C17] mb-2">@Model.Category</h2>
    <p class="text-gray-700 mb-2">@Model.Description</p>
    <p class="text-sm text-gray-500">Location: @Model.Location</p>
    <p class="text-sm text-gray-500">Status: <strong>@Model.Status</strong></p>

    @if (Model.Attachments != null && Model.Attachments.Any())
    {
        <div class="mt-4">
            <h4 class="font-medium">Attachments</h4>
            <div class="grid grid-cols-3 gap-3 mt-2">
                @foreach (var a in Model.Attachments)
                {
                    <a href="@a" target="_blank">
                        <img src="@a" class="rounded-lg shadow border" />
                    </a>
                }
            </div>
        </div>
    }

    <div class="mt-4">
        <a asp-action="All" class="text-[#3E7C17] underline">← Back to All Reports</a>
    </div>
</div>
