@model MunicipalityApp.Models.ReportIssueViewModel
@{
    ViewData["Title"] = "Report Issues";
}
<div>
    <a asp-controller="Home" asp-action="Index" class="bg-[#3E7C17] text-white px-4 py-2 rounded-lg hover:bg-[#2f6e13] transition">
        Back to Home
    </a>
</div>

<div class="max-w-5xl mx-auto">
    <div class="bg-white rounded-2xl p-6 shadow grid md:grid-cols-2 gap-6">
        <div>

            <h2 class="text-2xl font-semibold text-[#5C4033]">Report an Issue</h2>
            <p class="text-gray-600 mt-1">Provide the location, category and description. Attach images or documents.</p>

            <form asp-action="Report" asp-controller="Issues" method="post" enctype="multipart/form-data" class="mt-4">
                <div class="mb-3">
                    <label class="block text-sm">Location</label>
                    <input asp-for="Location" class="w-full p-2 border rounded" />
                    <span asp-validation-for="Location" class="text-red-600 text-sm"></span>
                </div>

                <div class="mb-3">
                    <label class="block text-sm">Category</label>
                    <select asp-for="SelectedCategory" class="w-full p-2 border rounded">
                        <option value="">-- choose --</option>
                        <option>Sanitation</option>
                        <option>Roads</option>
                        <option>Utilities</option>
                        <option>Water</option>
                        <option>Lighting</option>
                        <option>Safety</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="SelectedCategory" class="text-red-600 text-sm"></span>
                </div>

                <div class="mb-3">
                    <label class="block text-sm">Description</label>
                    <textarea asp-for="Description" rows="6" class="w-full p-2 border rounded"></textarea>
                    <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
                </div>

                <div class="mb-3">
                    <label class="block text-sm">Attachments</label>
                    <input type="file" name="Attachments" multiple class="w-full" id="attachmentsInput" accept="image/*,.pdf,.doc,.docx" />
                    <div id="attachmentsList" class="text-sm text-gray-500 mt-1"></div>
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="bg-[#3E7C17] text-white px-4 py-2 rounded">Submit</button>
                    <a href="~/Home/Index" class="px-4 py-2 rounded border">Back</a>
                </div>
            </form>
        </div>

        <div>
            <div class="bg-[#FAF9F6] p-4 rounded">
                <h4 class="font-semibold text-[#5C4033]">You're helping your community</h4>
                <p id="encouragement" class="text-gray-600 mt-2">Complete the form to improve response times.</p>

                <div class="mt-4">
                    <label class="text-sm">Progress</label>
                    <div class="w-full bg-gray-200 rounded-full h-4 mt-2">
                        <div id="progressBar" class="h-4 rounded-full bg-[#3E7C17] text-xs text-white text-center" style="width:0%">0%</div>
                    </div>
                </div>

                <div class="mt-4">
                    <h5 class="font-medium">Tips</h5>
                    <ul class="list-disc pl-5 text-sm text-gray-700">
                        <li>Attach clear photos.</li>
                        <li>Include landmarks for location clarity.</li>
                        <li>Be concise but specific.</li>
                    </ul>
                </div>

                <div class="mt-6">
                    <h5 class="font-medium">Recent (session)</h5>
                    <div id="recentSubmissions" class="text-sm text-gray-600 mt-2">No submissions yet.</div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/site.js"></script>
    }
</div>