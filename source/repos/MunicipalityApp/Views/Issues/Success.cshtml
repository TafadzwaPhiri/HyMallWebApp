@model MunicipalityApp.Models.Issue
@{
    ViewData["Title"] = "Report Submitted";
}
<div class="max-w-3xl mx-auto">
    <div class="bg-white p-6 rounded shadow">
        <h2 class="text-2xl font-semibold text-[#5C4033]">Thank you</h2>
        <p class="text-gray-600">Reference: <strong>@Model.Id</strong></p>

        <div class="mt-4">
            <p><strong>Location:</strong> @Model.Location</p>
            <p><strong>Category:</strong> @Model.Category</p>
            <p class="whitespace-pre-wrap"><strong>Description:</strong> @Model.Description</p>

            @if (Model.Attachments?.Any() == true)
            {
                <div class="mt-3">
                    <strong>Attachments</strong>
                    <div class="flex gap-2 mt-2">
                        @foreach (var a in Model.Attachments)
                        {
                            var ext = System.IO.Path.GetExtension(a).ToLower();
                            if (ext == ".pdf" || ext == ".doc" || ext == ".docx")
                            {
                                <a href="@a" target="_blank" class="text-sm underline">@System.IO.Path.GetFileName(a)</a>
                            }
                            else
                            {
                                <img src="@a" class="w-32 h-24 object-cover rounded" />
                            }
                        }
                    </div>
                </div>
            }

            <div class="mt-6">
                <a href="~/Home/Index" class="px-4 py-2 rounded border">Back to Menu</a>
                <a href="~/Issues/AllReports" class="ml-2 px-4 py-2 rounded bg-[#3E7C17] text-white">View All</a>
            </div>
        </div>
    </div>
</div>