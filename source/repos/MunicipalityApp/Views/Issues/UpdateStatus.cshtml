@model MunicipalityApp.Models.Issue

@{
    ViewData["Title"] = "Update Status";
}


<div class="bg-white rounded-2xl shadow hover:shadow-lg transition p-4 border border-gray-100">
    <h3 class="text-[#3E7C17] font-semibold">@Model.Category</h3>
    <p class="text-gray-700 text-sm mt-1">@Model.Description</p>

    <p class="text-xs text-gray-500 mt-2">Request ID: <strong>@Model.Id</strong></p>
    <p class="text-xs text-gray-500">
        Status:
        <span class="px-2 py-1 text-xs rounded-full 
            @(Model.Status == "Completed" ? "bg-green-100 text-green-700" : 
              Model.Status == "In Progress" ? "bg-yellow-100 text-yellow-700" : 
              "bg-gray-100 text-gray-700")">
            @Model.Status
        </span>
    </p>

    <form asp-action="UpdateStatus" method="post" class="mt-3 flex gap-2">
        <input type="hidden" name="id" value="@Model.Id" />
        <select name="status" class="border rounded p-1 text-sm">
            <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
            <option value="In Progress" selected="@(Model.Status == "In Progress")">In Progress</option>
            <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
        </select>
        <button type="submit" class="bg-[#3E7C17] text-white px-3 py-1 text-sm rounded hover:bg-[#2f6e13] transition">
            Update
        </button>
    </form>
</div>
