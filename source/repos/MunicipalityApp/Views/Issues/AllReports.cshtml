@model IEnumerable<MunicipalityApp.Models.Issue>
@{
    ViewData["Title"] = "All Reports";
}

<div>
    <a asp-controller="Home" asp-action="Index" class="bg-[#3E7C17] text-white px-4 py-2 rounded-lg hover:bg-[#2f6e13] transition">
        Back to Home
    </a>
</div>

<div class="container mt-4">
    <h2>All Reports</h2>
    <table class="table table-hover mt-4">
        <thead class="table-light">
            <tr>
                <th>Description</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var issue in Model)
            {
                <tr>
                    <td>@issue.Description</td>
                    <td>@issue.Status</td>
                    <td>@issue.CreatedAt.ToShortDateString()</td>
                    <td>
                        <a href="/Issues/UpdateStatus/@issue.Id" class="btn btn-outline-primary btn-sm rounded-pill">Update</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

 