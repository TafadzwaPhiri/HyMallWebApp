@model MunicipalityApp.Models.EventSearchModel
@{
    ViewData["Title"] = "Local Events";
}
<div>
    <a asp-controller="Home" asp-action="Index" class="bg-[#3E7C17] text-white px-4 py-2 rounded-lg hover:bg-[#2f6e13] transition">
        Back to Home
    </a>
</div>
<div class="max-w-6xl mx-auto">
    <div class="flex gap-4 items-center">
        <!-- ✅ FIXED: changed name from 'q' to 'search' -->
        <form method="get" class="flex gap-2 items-center">
            <input name="search" value="@Model.Query"
                   placeholder="Search events or tags..."
                   class="rounded-md border p-2 w-96 focus:ring-2 focus:ring-[#3a8a4a] outline-none" />
            <button class="px-4 py-2 rounded-full bg-[#3a8a4a] text-white hover:bg-[#317a3f] transition">
                Search
            </button>
        </form>
        <a href="/" class="text-sm text-gray-600 hover:underline">Back</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="md:col-span-2">
            <h3 class="text-lg font-semibold text-[#6b4f3b]">Results</h3>
            <div class="mt-3 space-y-3">
                @if (!Model.Results.Any())
                {
                    <div class="text-gray-600">No events found for '@Model.Query'</div>
                }
                else
                {
                    foreach (var e in Model.Results)
                    {
                        <div class="bg-white rounded-lg p-4 shadow hover:shadow-md transition">
                            <div class="flex justify-between">
                                <div>
                                    <div class="font-semibold text-[#3a8a4a]">@e.Title</div>
                                    <div class="text-sm text-gray-500">
                                        @e.Category • @e.Date.ToString("MMM d, yyyy")
                                    </div>
                                </div>
                                <div class="text-sm text-gray-600">Priority: @e.Priority</div>
                            </div>
                            <div class="mt-2 text-sm text-gray-700">@e.Description</div>
                            <div class="mt-2">
                                <a href="/Events/Details?id=@e.Id"
                                   class="text-[#3a8a4a] underline hover:text-[#2e6e35]">Details</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div>
            <h4 class="text-md font-semibold text-[#6b4f3b]">Recommendations</h4>
            <div class="space-y-3 mt-3">
                @if (!Model.Recommendations.Any())
                {
                    <div class="text-gray-600">No recommendations right now.</div>
                }
                else
                {
                    foreach (var r in Model.Recommendations)
                    {
                        <div class="bg-white rounded-lg p-3 shadow hover:shadow-md transition">
                            <div class="font-medium text-[#3a8a4a]">@r.Title</div>
                            <div class="text-sm text-gray-500">
                                @r.Category • @r.Date.ToString("d")
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
