@model MunicipalityApp.Models.EventSearchModel
@{
    ViewData["Title"] = "Local Events";
}

<div>
    <a asp-controller="Home" asp-action="Index" class="bg-[#3E7C17] text-white px-4 py-2 rounded-lg hover:bg-[#2f6e13] transition">
        Back to Home
    </a>
</div>

<div class="max-w-6xl mx-auto">
    <div class="flex gap-4 items-center">
        <form method="get" class="flex gap-2 items-center">
            <input name="q" value="@Model?.Query" placeholder="Search events or tags..." class="rounded p-2 border w-96" />
            <button class="px-4 py-2 rounded-full bg-[#3E7C17] text-white">Search</button>
        </form>
        <a href="~/Home/Index" class="text-sm text-gray-600">Back</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="md:col-span-2">
            <h3 class="text-lg font-semibold text-[#5C4033]">Results</h3>
            <div class="mt-3 space-y-3">
                @if (Model?.Results == null || !Model.Results.Any())
                {
                    <div class="text-gray-600">No events found.</div>
                }
                else
                {
                    foreach (var e in Model.Results)
                    {
                        <div class="bg-white p-4 rounded shadow">
                            <div class="flex justify-between">
                                <div>
                                    <div class="font-semibold">@e.Title</div>
                                    <div class="text-sm text-gray-500">@e.Category • @e.Date.ToString("MMM d, yyyy")</div>
                                </div>
                                <div class="text-sm text-gray-600">Priority: @e.Priority</div>
                            </div>
                            <div class="mt-2 text-sm text-gray-700">@e.Description</div>
                            <div class="mt-2">
                                <a href="~/Events/Details?id=@e.Id" class="text-[#3E7C17] underline">Details</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div>
            <h4 class="text-md font-semibold text-[#5C4033]">Recommendations</h4>
            <div class="space-y-3 mt-3">
                @if (Model?.Recommendations == null || !Model.Recommendations.Any())
                {
                    <div class="text-gray-600">No recommendations right now.</div>
                }
                else
                {
                    foreach (var r in Model.Recommendations)
                    {
                        <div class="bg-white p-3 rounded shadow">
                            <div class="font-medium">@r.Title</div>
                            <div class="text-sm text-gray-500">@r.Category • @r.Date.ToShortDateString()</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>