@model (IEnumerable<MunicipalityApp.Models.ServiceRequest> all, IEnumerable<MunicipalityApp.Models.ServiceRequest> bst)
@{
    ViewData["Title"] = "Service Request Status";
    var mst = ViewBag.MST as IEnumerable<(MunicipalityApp.Models.ServiceRequest, MunicipalityApp.Models.ServiceRequest)>;
}
<div class="max-w-6xl mx-auto">
    <h2 class="text-xl font-semibold text-[#5C4033]">Service Request Status</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        <div>
            <h3 class="font-medium">All Requests</h3>
            <div class="space-y-3 mt-3">
                @foreach (var r in Model.all)
                {
                    <div class="bg-white p-3 rounded shadow">
                        <div class="flex justify-between">
                            <div class="font-semibold">@r.Title</div>
                            <div class="text-sm text-gray-500">Priority: @r.Priority</div>
                        </div>
                        <div class="text-sm text-gray-600 mt-1">@r.Details</div>
                        <div class="mt-2">
                            <a href="~/ServiceRequest/Details?id=@r.Id" class="text-[#3E7C17] underline">View</a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div>
            <h3 class="font-medium">BST In-order (IDs)</h3>
            <div class="bg-white p-3 rounded shadow mt-3">
                <div class="text-sm text-gray-700">
                    @foreach (var b in Model.bst)
                    {
                        <div>Id: @b.Id — @b.Title</div>
                    }
                </div>
            </div>

            <h3 class="font-medium mt-4">Minimum Spanning Tree</h3>
            <div class="bg-white p-3 rounded shadow mt-3">
                @if (mst != null && mst.Any())
                {
                    foreach (var e in mst)
                    {
                        <div class="text-sm text-gray-700">@e.Item1.Title — @e.Item2.Title</div>
                    }
                }
                else
                {
                    <div class="text-sm text-gray-500">No graph links available.</div>
                }
            </div>
        </div>
    </div>
</div>
