@model List<MunicipalityApp.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Request Status";
}
<div>
    <a asp-controller="Home" asp-action="Index" class="bg-[#3E7C17] text-white px-4 py-2 rounded-lg hover:bg-[#2f6e13] transition">
        Back to Home
    </a>
</div>

<div class="max-w-6xl mx-auto p-6">
    <h2 class="text-3xl font-semibold text-[#3E7C17] mb-4">Service Requests</h2>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 text-green-800 p-3 rounded mb-4">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 text-red-800 p-3 rounded mb-4">@TempData["Error"]</div>
    }

    <!-- Submit Request Form -->
    <div class="bg-white p-5 rounded-2xl shadow mb-6">
        <h3 class="font-semibold text-lg text-[#5C4033] mb-3">Submit a New Service Request</h3>
        <form asp-action="SubmitRequest" method="post" class="grid md:grid-cols-3 gap-4">
            <input type="text" name="title" placeholder="Title" class="border rounded-xl p-3 focus:ring-2 focus:ring-[#3E7C17] focus:outline-none" required />
            <input type="text" name="details" placeholder="Details" class="border rounded-xl p-3 focus:ring-2 focus:ring-[#3E7C17] focus:outline-none" required />
            <div class="flex items-center gap-3">
                <input type="number" name="priority" placeholder="Priority (1-10)" class="border rounded-xl p-3 w-full focus:ring-2 focus:ring-[#3E7C17] focus:outline-none" required />
                <button type="submit" class="bg-[#3E7C17] text-white rounded-xl px-5 py-3 hover:bg-[#356d14] transition">
                    Add
                </button>
            </div>
        </form>
    </div>
    

    <!-- Display all requests -->
    <div class="grid md:grid-cols-3 sm:grid-cols-2 grid-cols-1 gap-6">
        @foreach (var req in Model)
        {
            <div class="bg-white rounded-2xl shadow hover:shadow-lg transition p-4 border border-gray-100">
                <h3 class="text-[#3E7C17] font-semibold">@req.Category</h3>
                <p class="text-gray-700 text-sm mt-1">@req.Description</p>

                <p class="text-xs text-gray-500 mt-2">Request ID: <strong>@req.Id</strong></p>
                <p class="text-xs text-gray-500">
                    Status:
                    <span class="px-2 py-1 text-xs rounded-full @(req.Status == "Completed" ? "bg-green-100 text-green-700" : req.Status == "In Progress" ? "bg-yellow-100 text-yellow-700" : "bg-gray-100 text-gray-700")">
                        @req.Status
                    </span>
                </p>

                <form asp-action="UpdateStatus" method="post" class="mt-3 flex gap-2">
                    <input type="hidden" name="id" value="@req.Id" />
                    <select name="newStatus" class="border rounded p-1 text-sm">
                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                    <button type="submit" class="bg-[#3E7C17] text-white px-3 py-1 text-sm rounded">Update</button>
                </form>
            </div>
        }
    </div>
</div>


<!-- Display Service Requests -->
<div class="row">
    @foreach (var req in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm p-3 rounded-4">
                <h5 class="fw-bold">@req.Title</h5>
                <p class="text-muted">@req.Details</p>
                <p><span class="badge bg-info text-dark">Priority: @req.Priority</span></p>
                <p><span class="badge bg-secondary">@req.Status</span></p>

                <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@req.Id" />
                    <select name="status" class="form-select">
                        <option>Pending</option>
                        <option>In Progress</option>
                        <option>Completed</option>
                    </select>
                    <button type="submit" class="btn btn-outline-primary btn-sm">Update</button>
                </form>
            </div>
        </div>
    }
</div>

<!-- Data Structures Visualization Section -->
<div class="container mt-5 mb-5">
    <h2 class="text-center mb-4 text-primary fw-bold">📊 Data Structures Overview</h2>

    <!-- BST In-Order Traversal -->
    <div class="card shadow-lg border-0 mb-4 rounded-4">
        <div class="card-body">
            <h4 class="card-title text-success mb-3">🌿 BST (In-Order Traversal)</h4>
            <div class="d-flex flex-wrap gap-3 justify-content-start">
                @foreach (var req in ViewBag.BST as IEnumerable<MunicipalityApp.Models.ServiceRequest>)
                {
                    <div class="p-3 bg-light rounded-4 shadow-sm" style="min-width: 200px;">
                        <h6 class="mb-1 fw-semibold">@req.Title</h6>
                        <p class="mb-0 text-muted small">ID: @req.Id</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Minimum Spanning Tree -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body">
            <h4 class="card-title text-info mb-3">🔗 Minimum Spanning Tree (MST)</h4>
            <div class="list-group">
                @foreach (var edge in ViewBag.MST as IEnumerable<(MunicipalityApp.Models.ServiceRequest, MunicipalityApp.Models.ServiceRequest)>)
                {
                    <div class="list-group-item border-0 bg-transparent p-2 d-flex align-items-center justify-content-between">
                        <span>
                            <i class="bi bi-diagram-3 text-secondary me-2"></i>
                            <strong>@edge.Item1.Title</strong>
                            <span class="text-muted">↔</span>
                            <strong>@edge.Item2.Title</strong>
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<style>
    .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    .bg-light {
        background-color: #f9fafc !important;
    }
</style>







